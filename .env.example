# SignLex Backend Environment Variables
# Copy to .env and fill in your values

PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/signlex

# Firebase Admin SDK
FIREBASE_PROJECT_ID=signlex-app
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@signlex-app.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# CORS
CLIENT_URL=http://localhost:3000
